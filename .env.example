# Cellular operator
APN=internet
GPRS_USER=
GPRS_PASS=
SIM_PIN=

# MQTT broker (TLS, port 8883)
MQTT_HOST=mqtt.example.com
MQTT_PORT=8883
MQTT_USER=device-01
MQTT_PASS=changeme
MQTT_CLIENT_ID=esp32-ppp-cmux-01

# Path (relative to firmware/) to a PEM file containing the broker root CA.
# Read at compile time via include_bytes!.
MQTT_CA_PEM=certs/ca.pem

# Fallback DNS in case IPCP doesn't deliver one (rare on most operators)
MQTT_DNS=8.8.8.8
